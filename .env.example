# --- DATABASE ---
DATABASE_URL=postgresql://finflow:finflow_secret@localhost:5432/finflow_db
DB_USER=finflow
DB_PASSWORD=finflow_secret
DB_NAME=finflow_db

# --- REDIS ---
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# --- AUTH ---
SECRET_KEY=finflow-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- FRONTEND ---
NEXTAUTH_SECRET=finflow-nextauth-secret-min-32-chars
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- AI (all optional - free fallback built-in) ---
OPENROUTER_API_KEY=        # free tier: openrouter.ai
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# --- OAUTH ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- PRODUCTION ---
DOMAIN=your-domain.com
ACME_EMAIL=admin@your-domain.com
